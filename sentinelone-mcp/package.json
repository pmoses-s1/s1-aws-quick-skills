{
  "name": "@pmoses-s1/sentinelone-mcp",
  "version": "1.2.1",
  "description": "MCP server orchestrating SentinelOne skills, APIs, and SOC analyst context. Stdio or Streamable HTTP transport with per-user bearer auth for team deployments.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "sentinelone-mcp": "./index.js"
  },
  "files": [
    "index.js",
    "lib/",
    "tools/",
    "deploy/",
    "scripts/",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node index.js",
    "start:http": "node index.js --transport http",
    "dev": "node --watch index.js",
    "test": "node --test tests/smoke.test.mjs tests/stdio-transport.test.mjs tests/http-transport.test.mjs",
    "regen:readme": "node scripts/regen-readme-tools-table.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pmoses-s1/claude-skills.git",
    "directory": "sentinelone-mcp"
  },
  "homepage": "https://github.com/pmoses-s1/claude-skills/tree/main/sentinelone-mcp#readme",
  "bugs": "https://github.com/pmoses-s1/claude-skills/issues",
  "keywords": [
    "mcp",
    "sentinelone",
    "model-context-protocol",
    "soc",
    "powerquery",
    "sdl",
    "singularity-data-lake",
    "claude"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
