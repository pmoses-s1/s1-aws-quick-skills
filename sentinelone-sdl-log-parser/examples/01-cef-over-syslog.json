// Syslog-framed CEF (Common Event Format).
//
// Sample line the parser targets:
//   <134>Feb 15 10:25:34 fw-01.example.com CEF:0|Vendor|Firewall|1.0|100|Connection Allowed|5|src=192.168.1.10 dst=10.0.0.5 spt=12345 dpt=80 proto=TCP act=allowed
//
// Extraction plan:
//   <pri>         -> syslogPriority  (facility, rawSeverity, severity)
//   Feb 15 ...    -> timestamp
//   fw-01...      -> host
//   CEF:0|...|7|  -> positional CEF header (cefVersion, vendor, product, product_version, signature_id, name, severity_raw)
//   key=value...  -> repeating key/value catch-all, names become event fields
//
// Notes:
//   - Timezone is set at parser level because classic-syslog timestamps lack one.
//     Switch to the collector's actual TZ if not UTC.
//   - The CEF header is pipe-delimited and fixed-position; we use a single format with
//     literal `|` delimiters. The extension is freeform so we use a repeating fragment.
//   - discardAttributes drops the raw message to save storage once fields are parsed.

{
  timezone: "UTC",
  attributes: {
    // Required pipeline defaults.
    "metadata.version":    "1.0.0",
    "dataSource.category": "security",
    "dataSource.name":     "Generic CEF Firewall",
    "dataSource.vendor":   "Vendor",
    // Legacy vendor tags.
    vendor:  "Vendor",
    product: "Firewall",
    dataset: "cef"
  },

  patterns: {
    // Classic-syslog timestamp: "Feb 15 10:25:34" (month may be 1-3 spaces between day).
    syslogTs: "[A-Z][a-z]{2}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2}",
    // CEF pipe-delimited field body: anything that isn't a pipe. Required because the
    // CEF `name` field is free-form text WITH SPACES ("Connection Allowed"), and the
    // default capture (`quotable`) stops at whitespace â€” so the format silently fails
    // to match. `notPipe` lets the capture span spaces up to the next `|`.
    notPipe:  "[^|]*"
  },

  formats: [
    // Format 1: anchor the full CEF frame and capture everything up to the pipe-7 body
    // delimiter.
    //
    // NOTE: `{parse=syslogPriority}` and capturing into the reserved `timestamp`
    // field both silently drop events on this tenant. Capture priority as a plain
    // digit field and capture the classic-syslog stamp as `ts_raw` (we're ingesting
    // close to real-time so the pipeline's own receive-time is fine).
    //
    // DO NOT set `halt: true` here â€” the extension k/v extractor below must still
    // run on the same line to populate `src`, `dst`, etc. With halt, format 1
    // still matches and emits the header fields, but the event ends up with a
    // null `src`/`dst`.
    {
      id: "cef-header",
      format: "<$pri=digits$>$ts_raw=syslogTs$ $host$ CEF:$cefVersion=notPipe$\\|$cef_vendor=notPipe$\\|$cef_product=notPipe$\\|$cef_version=notPipe$\\|$signature_id=notPipe$\\|$name=notPipe$\\|$cef_severity=notPipe$\\|$extension$"
    },

    // Format 2: fragment that re-reads the full line and extracts every k=v pair.
    // The `_` special field name twice captures both the key name and the value
    // dynamically. `repeat: true` is required so more than the first pair is
    // captured.
    {
      id: "cef-extension",
      format: ".*$_=identifier$=$_=quoteOrSpace$",
      repeat: true
    }
  ],

  // Drop the raw event text once we've pulled fields out. Comment this out while
  // iterating so you can still see the raw message during validation queries.
  discardAttributes: ["message"]
}
